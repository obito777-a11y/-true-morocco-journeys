# ─────────────────────────────────────────────────────────────────────────────
# True Morocco Journeys — Django Backend · Environment Variables
# Copy this file to .env and fill in your values. Never commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# Django core
SECRET_KEY=your-secret-key-change-me-use-django-get-random-secret-key
DEBUG=True
PORT=8000

# Allowed hosts (comma-separated, no spaces)
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Email (Gmail SMTP with App Password) ────────────────────────────────────
# Create an App Password at: https://myaccount.google.com/apppasswords
EMAIL_HOST_USER=your-gmail@gmail.com
EMAIL_HOST_PASSWORD=xxxx xxxx xxxx xxxx

# The inbox that receives contact / booking notifications
ADMIN_EMAIL=owner@truemoroccojourney.com

# ─── Agency branding (used in email templates) ───────────────────────────────
AGENCY_NAME=True Morocco Journeys
AGENCY_PHONE=+212 XXX XXX XXX
AGENCY_WEBSITE=https://truemoroccojourney.com

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slash)
FRONTEND_URL=http://localhost:5500,http://127.0.0.1:5500,https://truemoroccojourney.com
